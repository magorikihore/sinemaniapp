{
    "cli": {
        "version": ">= 3.0.0",
        "appVersionSource": "remote"
    },
    "build": {
        "preview": {
            "distribution": "internal",
            "android": {
                "buildType": "apk",
                "gradleCommand": ":app:assembleRelease"
            },
            "ios": {
                "simulator": true
            }
        },
        "preview-device": {
            "distribution": "internal",
            "ios": {
                "simulator": false
            }
        },
        "production": {
            "autoIncrement": true,
            "android": {
                "buildType": "app-bundle"
            },
            "ios": {
                "image": "macos-sequoia-15.6-xcode-26.1"
            }
        }
    },
    "submit": {
        "production": {
            "ios": {
                "ascAppId": "6763335960",
                "appleTeamId": "GB8B46629H"
            }
        }
    }
}